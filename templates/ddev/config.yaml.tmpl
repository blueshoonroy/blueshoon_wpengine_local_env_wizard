# Generated by the WPEngine Local Env Wizard.
# To customize locally, use .ddev/.env or .ddev/config.local.yaml
# See https://ddev.readthedocs.io/en/stable/users/configuration/config/

name: __PROJECT_NAME__

disable_settings_management: true

type: wordpress
docroot: ""
php_version: "__PHP_VERSION__"
webserver_type: nginx-fpm
database:
    type: mysql
    version: "__MYSQL_VERSION__"

web_environment:
    - WPENGINE_ENV=__WPENGINE_ENV__
    - REMOTE_DOMAIN=__REMOTE_DOMAIN__
    - WORDPRESS_VERSION=__WORDPRESS_VERSION__
    - WP_CLI_CACHE_DIR=/var/www/html/.ddev/.wp-cli/cache
    - WP_CLI_PACKAGES_DIR=/var/www/html/.ddev/.wp-cli/packages

hooks:
    pre-start:
        - exec-host: "ddev config-ssh"
    post-start:
        - exec-host: "ddev update-wp --initialize-only"
        - exec-host: "ddev config-wp --initialize-only"
        - exec-host: "ddev update-db --initialize-only"
        - exec-host: "ddev update-plugins --initialize-only"
        - exec-host: "ddev build --initialize-only"
    post-import-db:
        - exec: "echo Replacing https://$REMOTE_DOMAIN with $DDEV_PRIMARY_URL"
        - exec: "wp search-replace https://$REMOTE_DOMAIN $DDEV_PRIMARY_URL --precise --skip-columns=guid"
        - exec: "wp cache flush"
